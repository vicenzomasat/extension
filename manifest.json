{\n  "manifest_version": 3,\n  "name": "Privacy Shield - Fingerprint Blocker",\n  "version": "1.1.0",\n  "description": "Oculta el fingerprint del navegador manteniendo la compatibilidad con sitios seguros",\n  "permissions": [\n    "storage",\n    "activeTab",\n    "tabs"\n  ],\n  "host_permissions": [\n    "<all_urls>"\n  ],\n  "content_scripts": [\n    {\n      "matches": ["<all_urls>"],\n      "js": ["content.js"],\n      "run_at": "document_start",\n      "all_frames": true,\n      "match_about_blank": true,\n      "match_origin_as_fallback": true\n    }\n  ],\n  "background": {\n    "service_worker": "background.js",\n    "type": "module"\n  },\n  "action": {\n    "default_popup": "popup.html",\n    "default_title": "Privacy Shield"\n  },\n  "options_ui": {\n    "page": "options.html",\n    "open_in_tab": true\n  },\n  "web_accessible_resources": [\n    {\n      "resources": [\n        "data/personas.json"\n      ],\n      "matches": ["<all_urls>"]\n    }\n  ],\n  "icons": {\n    "16": "icons/icon16.png",\n    "48": "icons/icon48.png",\n    "128": "icons/icon128.png"\n  }\n}